# AI Provider - Use either OpenAI or Gemini
OPENAI_API_KEY=your_openai_api_key_here

# Redis (optional for MVP - falls back to in-memory cache)
REDIS_URL=redis://localhost:6379
# Or build from parts
# REDIS_HOST=your_redis_host
# REDIS_PORT=6379
# REDIS_USERNAME=default
# REDIS_TOKEN=your_redis_token
# REDIS_TLS=true

# PostgreSQL (optional - enables persistence)
DATABASE_URL=postgresql://cortexflow:cortexflow_password@localhost:5432/cortexflow
DB_HOST=localhost
DB_PORT=5432
DB_USER=cortexflow
DB_PASSWORD=cortexflow_password
DB_NAME=cortexflow

# Server
PORT=3001
